rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    /** Профил и лични подколекции — само собственикът пише. */
    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if isSelf(userId) && request.resource.data.uid == userId;
      allow delete: if isSelf(userId);

      match /catches/{catchId} {
        allow read, write: if isSelf(userId);
      }
      match /spots/{spotId} {
        allow read, write: if isSelf(userId);
      }
      /** Всеки логнат вижда следванията (взаимно следване, чат, брой последователи). */
      match /following/{targetUid} {
        allow read: if signedIn();
        allow write: if isSelf(userId);
      }
      match /joinedTournaments/{tid} {
        allow read, write: if isSelf(userId);
      }

      /** Запазени публикации от лентата (отметка). */
      match /savedCatches/{catchId} {
        allow read, write: if isSelf(userId);
      }

      /** Известия за харесвания и коментари по мои публични улови. */
      match /notifications/{nid} {
        allow read, delete: if isSelf(userId);
        allow create: if signedIn()
          && request.auth.uid != userId
          && request.resource.data.actorUid == request.auth.uid
          && request.resource.data.actorName is string
          && request.resource.data.actorName.size() <= 120
          && request.resource.data.type in ['like', 'comment', 'follow']
          && request.resource.data.catchId is string
          && request.resource.data.catchId.size() <= 128
          && request.resource.data.preview is string
          && request.resource.data.preview.size() <= 200
          && request.resource.data.read == false
          && (
            (request.resource.data.type == 'follow'
              && request.resource.data.catchId == ''
              && request.resource.data.preview == '')
            || (request.resource.data.type != 'follow'
              && request.resource.data.catchId.size() > 0)
          );
        allow update: if isSelf(userId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
          && request.resource.data.read == true;
      }
    }

    /** Публичен feed: четене за логнати; запис само собственикът на улова. */
    match /publicCatches/{catchId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && (!('photoTitle' in request.resource.data)
          || (request.resource.data.photoTitle is string && request.resource.data.photoTitle.size() <= 120));
      allow delete: if signedIn() && resource.data.ownerUid == request.auth.uid;

      match /likes/{uid} {
        allow read: if signedIn();
        allow write: if isSelf(uid);
      }
      match /dislikes/{uid} {
        allow read: if signedIn();
        allow write: if isSelf(uid);
      }
      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.authorName is string
          && request.resource.data.authorName.size() <= 120
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000;
        allow update, delete: if signedIn()
          && resource.data.authorUid == request.auth.uid;
      }
    }

    /** Доклади за злоупотреба — без четене от клиенти; запис само от логнат потребител. */
    match /contentReports/{reportId} {
      allow read: if false;
      allow create: if signedIn()
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.targetType in ['catch', 'comment']
        && request.resource.data.catchId is string
        && request.resource.data.catchId.size() >= 1
        && request.resource.data.catchId.size() <= 128
        && request.resource.data.reason is string
        && request.resource.data.reason.size() >= 3
        && request.resource.data.reason.size() <= 500
        && (!('commentId' in request.resource.data)
          || (request.resource.data.commentId is string && request.resource.data.commentId.size() <= 128));
      allow update, delete: if false;
    }

    match /tournaments/{tid} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.hostUid == request.auth.uid;
      allow update, delete: if signedIn()
        && resource.data.hostUid == request.auth.uid;

      match /participants/{uid} {
        allow read: if signedIn();
        allow create, update: if isSelf(uid);
        allow delete: if signedIn() && (
          isSelf(uid)
          || get(/databases/$(database)/documents/tournaments/$(tid)).data.hostUid == request.auth.uid
        );
      }

      match /entries/{catchId} {
        allow read: if signedIn();
        allow create, update: if signedIn()
          && request.resource.data.ownerUid == request.auth.uid;
        allow delete: if signedIn() && (
          resource.data.ownerUid == request.auth.uid
          || get(/databases/$(database)/documents/tournaments/$(tid)).data.hostUid == request.auth.uid
        );
      }
    }

    /** Фийд със снимки по язовир — само логнати; запис само за свои публикации. */
    match /damFeeds/{damId}/feedPosts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.damId == damId
        && request.resource.data.photoUrl is string
        && request.resource.data.storagePath is string;
      allow update: if false;
      allow delete: if signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    /** Директни съобщения — само двамата участници. */
    match /conversations/{convId} {
      allow read: if signedIn() && request.auth.uid in resource.data.participantIds;
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.participantIds
        && request.resource.data.participantIds.size() == 2;
      allow update: if signedIn()
        && request.auth.uid in resource.data.participantIds
        && request.resource.data.participantIds == resource.data.participantIds;
      allow delete: if false;

      match /messages/{msgId} {
        allow read: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participantIds;
        allow create: if signedIn()
          && request.resource.data.senderUid == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participantIds;
        allow update, delete: if false;
      }
    }
  }
}
