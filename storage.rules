rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function underLimit() {
      return request.resource.size < 10 * 1024 * 1024; // 10 MB
    }

    match /profilePhotos/{userId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn()
        && request.auth.uid == userId
        && isImage()
        && underLimit();
    }

    match /publicCatchPhotos/{userId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn()
        && request.auth.uid == userId
        && isImage()
        && underLimit();
    }

    match /damFeeds/{damId}/{userId}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn()
        && request.auth.uid == userId
        && isImage()
        && underLimit();
    }
  }
}
